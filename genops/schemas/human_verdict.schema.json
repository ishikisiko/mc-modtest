{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myvillage.local/genops/human_verdict.schema.json",
  "title": "GenOps Human Verdict",
  "type": "object",
  "required": ["target", "verdict", "human_note"],
  "properties": {
    "target": {"type": "string"},
    "verdict": {"enum": ["pending", "accept", "reject", "accept_with_changes", "not_required", "pause", "reopen_discussion"]},
    "human_note": {"type": "string"},
    "accepted_defects": {"type": "array", "items": {"type": "string"}},
    "blocking_defects": {"type": "array", "items": {"type": "string"}}
  }
}
